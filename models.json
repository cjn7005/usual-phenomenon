{
  "customers": {
    "singular": "customer",
    "object_name": "Customer",
    "pk": "customer_id",
    "attributes": {
      "customer_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "GENERATED BY DEFAULT AS IDENTITY"
      },
      "first_name": {
        "python_type": "str",
        "sql_type": "VARCHAR(100)",
        "column_arguments": "NOT NULL",
        "sample": "Alice"
      },
      "last_name": {
        "python_type": "str",
        "sql_type": "VARCHAR(100)",
        "column_arguments": "NOT NULL",
        "sample": "Johnson"
      },
      "email": {
        "python_type": "str",
        "sql_type": "VARCHAR(255)",
        "column_arguments": "UNIQUE NOT NULL",
        "sample": "alice.johnson@example.com"
      },
      "created_at": {
        "python_type": "datetime",
        "sql_type": "TIMESTAMP",
        "column_arguments": "DEFAULT CURRENT_TIMESTAMP"
      }
    }
  },
  "products": {
    "singular": "product",
    "object_name": "Product",
    "pk": "product_id",
    "attributes": {
      "product_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "GENERATED BY DEFAULT AS IDENTITY"
      },
      "name": {
        "python_type": "str",
        "sql_type": "VARCHAR(255)",
        "column_arguments": "NOT NULL",
        "sample": "Wireless Mouse"
      },
      "price": {
        "python_type": "float",
        "sql_type": "DECIMAL(10,2)",
        "column_arguments": "NOT NULL",
        "sample": 29.99
      },
      "stock_quantity": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "DEFAULT 0"
      }
    }
  },
  "orders": {
    "singular": "order",
    "object_name": "Order",
    "pk": "order_id",
    "attributes": {
      "order_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "GENERATED BY DEFAULT AS IDENTITY"
      },
      "customer_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "NOT NULL REFERENCES customers(customer_id)"
      },
      "order_date": {
        "python_type": "datetime",
        "sql_type": "TIMESTAMP",
        "column_arguments": "DEFAULT CURRENT_TIMESTAMP"
      },
      "status": {
        "python_type": "str",
        "sql_type": "VARCHAR(50)",
        "column_arguments": "DEFAULT 'pending'"
      }
    }
  },
  "order_items": {
    "singular": "order_item",
    "object_name": "OrderItem",
    "pk": "order_item_id",
    "attributes": {
      "order_item_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "GENERATED BY DEFAULT AS IDENTITY"
      },
      "order_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "NOT NULL REFERENCES orders(order_id)"
      },
      "product_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "NOT NULL REFERENCES products(product_id)"
      },
      "quantity": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "NOT NULL",
        "sample": 2
      },
      "unit_price": {
        "python_type": "float",
        "sql_type": "DECIMAL(10,2)",
        "column_arguments": "NOT NULL",
        "sample": 29.99
      }
    }
  },
  "payments": {
    "singular": "payment",
    "object_name": "Payment",
    "pk": "payment_id",
    "attributes": {
      "payment_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "GENERATED BY DEFAULT AS IDENTITY"
      },
      "order_id": {
        "python_type": "int",
        "sql_type": "INTEGER",
        "column_arguments": "NOT NULL REFERENCES orders(order_id)"
      },
      "amount": {
        "python_type": "float",
        "sql_type": "DECIMAL(10,2)",
        "column_arguments": "NOT NULL",
        "sample": 59.98
      },
      "payment_method": {
        "python_type": "str",
        "sql_type": "VARCHAR(50)",
        "column_arguments": "NOT NULL",
        "sample": "credit_card"
      },
      "paid_at": {
        "python_type": "datetime",
        "sql_type": "TIMESTAMP",
        "column_arguments": "DEFAULT CURRENT_TIMESTAMP"
      }
    }
  }
}